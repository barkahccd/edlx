{
  "manifest_version": 3,
  "name": "Edel Cookie Exporter",
  "version": "1.0",
  "description": "One-click copy edel_session cookie for Edel Runway Bot",
  "permissions": [
    "cookies",
    "clipboardWrite"
  ],
  "host_permissions": [
    "*://runway.edel.finance/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}